{
  "version": 2,
  "builds": [
    {
      "src": "python_api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "150mb"
      }
    },
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/exam/(.*)",
      "dest": "python_api/index.py"
    },
    {
      "src": "/api/admin/(.*)",
      "dest": "python_api/index.py"
    },
    {
      "src": "/api/ai/(.*)",
      "dest": "python_api/index.py"
    },
    {
      "src": "/api/auth/(.*)",
      "dest": "python_api/index.py"
    },
    {
      "src": "/api/py/(.*)",
      "dest": "python_api/index.py"
    },
    {
      "src": "/_next/static/(.*)",
      "dest": "/_next/static/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
