{
  "version": 2,
  "builds": [
    {
      "src": "python_api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "150mb"
      }
    },
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "python_api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
